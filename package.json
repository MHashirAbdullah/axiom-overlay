{
  "name": "axiom-overlay",
  "version": "0.1.0",
  "description": "Axiom real-time meeting & interview assistant overlay",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"vite\" \"cross-env NODE_ENV=development electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "ai.axiom.overlay",
    "productName": "Axiom Overlay",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "public/axiom-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": ["dist/**/*", "dist-electron/**/*"]
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "groq-sdk": "^1.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
