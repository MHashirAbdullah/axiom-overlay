# Supabase — same project as meeting-scribe-web
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Axiom API base URL (your Next.js deployment)
VITE_API_BASE_URL=https://axiom-prod.vercel.app

# Groq API key — used directly in renderer for Whisper transcription
# Get one free at console.groq.com
VITE_GROQ_API_KEY=gsk_your_groq_api_key
